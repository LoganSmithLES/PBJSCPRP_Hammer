"LightmappedGeneric"
{
   "$basetexture" "ttt_foundation\checkpoint_lockdown"
   "$surfaceprop" "glass"
   "Proxies"
   {
      "AnimatedTexture"
      {
         "animatedtexturevar" "$basetexture"
         "animatedtextureframenumvar" "$frame"
         "animatedtextureframerate" "1"
      }
   }
}