VertexLitGeneric
{
    $basetexture "models\props_rpd\benchinterior03_diff"
    $bumpmap "models\props_rpd\benchinterior03_norm"
    $normalmapalphaenvmapmask 1
    $envmap env_cubemap
    $envmaptint "[.1 .1 .1]"
    $phong "1"
    $phongexponent "40"
    $phongboost "2"
    $phongfresnelranges "[0.5 2 4]"
}
