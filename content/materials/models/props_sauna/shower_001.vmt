"VertexLitGeneric"
{
	"$baseTexture" 		"models/props_sauna/shower_001"

"$envmap" "env_cubemap"
"$basealphaenvmapmask" "1"
"$envmaptint""[0.5 0.5 0.5]"
"$basemapalphaphongmask" "1"

"$halflambert" "1"
"$phong" "1"
"$phongexponent" "20"
"$phongboost" "4"
"$phongfresnelranges" "[0.5 0.5 1]"

 "$bumpmap" "models/props_sauna/shower_001_normal"

}

