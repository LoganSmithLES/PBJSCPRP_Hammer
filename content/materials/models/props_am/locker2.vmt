//"EDITOR_SHADER"
"VertexLitGeneric"
{
"$SHADERNAME" "model_standard"

"$basetexture" "models\props_am\locker2"
"$bumpmap" "models\props_am\locker2_nm"

//metal
"$normalmapalphaenvmapmask" "1"
"$envmap" "env_cubemap"
"$envmaptint" "[.2 .2 .1]"
//"$envmapfalloff" "1"

// Phong Schtuff
"$phong" "1"
//"$phongexponent" 50"
"$phongboost" "1"
"$phongfresnelranges"	"[0.4 0.6 1.6]"
"$phongalbedotint" "1"


// Rim lighting parameters
"$rimlight" "1"
"$rimlightexponent" "25"
"$rimlightboost" "1"
}