"VertexLitGeneric"
{
	"$basetexture" 					"models\props_am\lab1d"
	"$bumpmap" 						"models\props_am\lab2windowframe_nm"
	"$normalmapalphaenvmapmask" 	"1"
	
	"$envmap" 						"env_cubemap"
	"$envmaptint" 					"[.2 .2 .2]"
	
	"$phong" 						"1"
	"$phongexponent" 				"7"
	"$phongboost"					"1"
	$phongfresnelranges 			"[.4 .8 30]"

	"$halflambert" 					"1"
	"$multipass" 					"1"
	"$model" 						"1"

	// Rim lighting parameters
	"$rimlight" 					"1"				// To enable rim lighting (requires phong)
	"$rimlightexponent" 			"35"			// Exponent for phong component of rim lighting
	"$rimlightboost" 				".2"			// Boost for ambient cube component 
	
	"$detail" 						"detail/brushedmetal.vtf"
	"$detailscale" 					"20"
	"$detailblendfactor" 			".5"
	"$detailblendmode" 				"0"
}