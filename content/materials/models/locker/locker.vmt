"VertexLitGeneric"
{
         $detail detail\sl_metal_detail2
         $detailscale 4.609
         $detailblendfactor .65
         $detailblendmode 0

	"$basetexture" "models/locker/locker"
	"$surfaceprop" "METAL"


	"$envmapmask" "models/locker/locker_mask"
	"$envmaptint" "[ 0.61 0.51 0.51 ]"
	"$envmap" "env_cubemap"
	"$envmapcontrast" 1
	"$envmapsaturation" 1
}
